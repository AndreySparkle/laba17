<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/shop_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/profile"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/profilePhoto"
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/profile_photo_background"
            android:clipToOutline="true"
            android:contentDescription="@string/profile_photo"
            android:padding="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile_large" />

        <Button
            android:id="@+id/changePhotoButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/change_photo" />

        <TextView
            android:id="@+id/profileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profilePhone"
            style="@style/ProfileValue" />

        <TextView
            android:id="@+id/profileEmail"
            style="@style/ProfileValue" />

        <Button
            android:id="@+id/editProfileButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="@string/edit_profile" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/loyalty_card"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.example.laba17.presentation.profile.QrCodeView
            android:id="@+id/profileQr"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="14dp"
            android:background="@color/white"
            android:contentDescription="@string/loyalty_qr"
            android:padding="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/tap_qr"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
</ScrollView>
